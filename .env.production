# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ============================================
# APPLICATION
# ============================================
APP_NAME=Sanitary ERP
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ============================================
# DATABASE
# ============================================
DB_USER=erp_production_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_123!
DB_NAME=sanitary_erp_production
DATABASE_URL=postgresql+asyncpg://erp_production_user:CHANGE_ME_STRONG_PASSWORD_123!@postgres:5432/sanitary_erp_production

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# JWT SECURITY (Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
# ============================================
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# PASSWORD POLICY
# ============================================
PASSWORD_MIN_LENGTH=10
PASSWORD_MAX_LENGTH=100
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
LOGIN_RATE_LIMIT_PER_MINUTE=10

# ============================================
# ACCOUNT LOCKOUT
# ============================================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ============================================
# FILE UPLOAD
# ============================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760

# ============================================
# CORS (Your production domain)
# ============================================
CORS_ORIGINS=["https://erp.yourdomain.com","https://www.erp.yourdomain.com"]

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY=sk-your-openai-key
AI_GEMINI_API_KEY=your-gemini-api-key
AI_GEMINI_MODEL=gemini-1.5-pro
AI_REQUIRE_USER_REVIEW=true

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_API_SECRET_KEY=CHANGE_ME_RANDOM_STRING

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ============================================
# SSL/TLS (for Let's Encrypt)
# ============================================
SSL_EMAIL=admin@yourdomain.com
